{
  "name": "interest-test",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run questions:check && next build",
    "lint": "eslint .",
    "test": "node --test scripts/lib/question-parser.node-test.mjs && vitest run",
    "questions:generate": "node scripts/generate-question-data.mjs",
    "questions:check": "node scripts/generate-question-data.mjs --check",
    "score:simulate": "tsx scripts/simulate-score.ts"
  },
  "dependencies": {
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "4.3.0",
    "tsx": "^4.0.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
